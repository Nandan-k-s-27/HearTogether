# Port for the Express server
PORT=3001

# Allowed frontend origin (no trailing slash)
FRONTEND_URL=http://localhost:5173

# Optional: custom TURN server for WebRTC NAT traversal.
# Without these the server falls back to the public Open Relay TURN servers
# which are fine for development but have limited bandwidth.
# For production get credentials from e.g. https://www.metered.ca/tools/openrelay/
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
