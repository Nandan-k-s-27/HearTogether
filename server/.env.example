# Port for the Express server (Render sets this automatically)
PORT=3001

# Allowed frontend origin - no trailing slash.
# Comma-separated for multiple origins:
# FRONTEND_URL=https://your-app.vercel.app,https://www.your-app.com
FRONTEND_URL=http://localhost:5173

# JWT signing key used for auth tokens.
# Use a long, random secret in all environments.
JWT_SECRET=replace_with_a_long_random_secret

# Google OAuth credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Redis (optional)
# In production, if REDIS_URL is not set (or points to localhost), Redis
# integration auto-disables to avoid reconnect loops.
# REDIS_ENABLED=true
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_CONNECT_TIMEOUT_MS=4000

# ---------------------------------------------------------------
# TURN relay (ExpressTurn recommended) - REQUIRED for audio on
# mobile / cellular networks.
#
# Preferred environment variable names:
# EXPRESSTURN_URLS=turn:...,turn:...?transport=tcp,turns:... (comma-separated)
# EXPRESSTURN_USERNAME=...
# EXPRESSTURN_CREDENTIAL=...
# Note: include turn:/turns: scheme when possible. If you provide host:port
# values, the server will auto-convert them to turn:host:port.
#
# Backward-compatible names also supported by the server:
# TURN_URLS, TURN_USERNAME, TURN_CREDENTIAL
# ---------------------------------------------------------------
TURN_PROVIDER=ExpressTurn
EXPRESSTURN_URLS=
EXPRESSTURN_USERNAME=
EXPRESSTURN_CREDENTIAL=
