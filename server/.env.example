# Port for the Express server (Render sets this automatically)
PORT=3001

# Allowed frontend origin - no trailing slash.
# Comma-separated for multiple origins:
# FRONTEND_URL=https://your-app.vercel.app,https://www.your-app.com
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------
# TURN relay - REQUIRED for audio on mobile / cellular networks.
# Use the Metered.ca FREE plan (0.5 GB/month, no credit card needed).
#
# How to get your credentials:
#   1. Sign up free at https://dashboard.metered.ca/signup
#   2. Create an App (any name)
#   3. Go to the app -> 'TURN Server Credentials'
#   4. Copy the Username and Credential shown there
#   5. Under 'TURN Server URLs', copy all 4 URLs
#
# TURN_URLS is a comma-separated list of all 4 TURN URLs, e.g.:
# turn:global.relay.metered.ca:80,turn:global.relay.metered.ca:80?transport=tcp,turn:global.relay.metered.ca:443,turns:global.relay.metered.ca:443?transport=tcp
# ---------------------------------------------------------------
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=
